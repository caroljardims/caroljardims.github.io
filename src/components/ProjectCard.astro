---
export interface Props {
  title: string;
  description: string;
  tags: string[];
  link: string;
  type: 'free' | 'paid';
}

const { title, description, tags, link, type } = Astro.props;
---

<a href={link} target="_blank" rel="noopener noreferrer" class="group block h-full">
  <div class="h-full p-6 rounded-lg bg-white dark:bg-slate-800 border border-peachy-200 dark:border-slate-700 hover:shadow-lg hover:border-peachy-500 dark:hover:border-peachy-400 transition-all duration-300">
    <div class="flex items-start justify-between mb-3">
      <h3 class="text-lg font-semibold text-slate-900 dark:text-white group-hover:text-peachy-600 dark:group-hover:text-peachy-400 transition-colors">
        {title}
      </h3>
      <span class={`px-2 py-1 rounded text-xs font-semibold ${type === 'paid' ? 'bg-peachy-100 dark:bg-peachy-900 text-peachy-700 dark:text-peachy-300' : 'bg-neutral-100 dark:bg-slate-700 text-slate-700 dark:text-slate-300'}`}>
        {type === 'paid' ? 'premium' : 'grátis'}
      </span>
    </div>
    <p class="text-slate-600 dark:text-slate-400 mb-4 text-sm leading-relaxed">
      {description}
    </p>
    <div class="flex flex-wrap gap-2">
      {tags.map((tag) => (
        <span class="px-2 py-1 rounded-full bg-peachy-100 dark:bg-slate-700 text-peachy-700 dark:text-peachy-300 text-xs font-medium">
          {tag}
        </span>
      ))}
    </div>
  </div>
</a>
