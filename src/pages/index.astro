---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { DarkModeToggle } from '../components/DarkModeToggle.tsx';
import { projects } from '../data/projects';
---

<Layout title="Carol Jardim - Mobile Developer">
  <!-- Navigation -->
  <nav class="fixed top-0 left-0 right-0 z-50 bg-white dark:bg-slate-900 border-b border-peachy-200 dark:border-slate-800 backdrop-blur-sm bg-opacity-95 dark:bg-opacity-95">
    <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-peachy-300 to-peachy-500 flex items-center justify-center text-white font-bold text-lg">C</div>
        <span class="font-bold text-xl text-slate-900 dark:text-white">carol</span>
      </div>
      <div class="flex items-center gap-6">
        <a href="#projects" class="text-slate-600 dark:text-slate-400 hover:text-peachy-600 dark:hover:text-peachy-400 transition-colors font-medium">Projects</a>
        <a href="https://github.com/caroljardims" target="_blank" rel="noopener noreferrer" class="text-slate-600 dark:text-slate-400 hover:text-peachy-600 dark:hover:text-peachy-400 transition-colors font-medium">GitHub</a>
        <DarkModeToggle client:load />
      </div>
    </div>
  </nav>

  <!-- Hero Section -->
  <section class="pt-32 pb-20 px-6">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="text-5xl md:text-6xl font-bold text-slate-900 dark:text-white mb-6 leading-tight">
        Frontend of my brain for projects ✨
      </h1>
      <p class="text-xl text-slate-600 dark:text-slate-400 mb-12 leading-relaxed">
        I'm Carol, a mobile developer specializing in iOS, Android, and React Native. I build beautiful, functional applications that solve real problems.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a 
          href="#projects"
          class="inline-block px-8 py-3 bg-peachy-500 hover:bg-peachy-600 text-white font-semibold rounded-lg transition-colors"
        >
          See My Work
        </a>
        <a 
          href="https://github.com/caroljardims"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block px-8 py-3 bg-peachy-100 dark:bg-slate-800 text-slate-900 dark:text-white hover:bg-peachy-200 dark:hover:bg-slate-700 font-semibold rounded-lg transition-colors border border-peachy-300 dark:border-slate-700"
        >
          View on GitHub
        </a>
      </div>
    </div>
  </section>

  <!-- Projects Section -->
  <section id="projects" class="py-20 px-6 bg-peachy-50 dark:bg-slate-800">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-4xl font-bold text-slate-900 dark:text-white mb-4 text-center">
        Featured Projects
      </h2>
      <p class="text-center text-slate-600 dark:text-slate-400 mb-12">
        A selection of my recent work. More coming soon! 🚀
      </p>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {projects.map((project) => (
          <ProjectCard
            title={project.title}
            description={project.description}
            tags={project.tags}
            link={project.link}
            type={project.type}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="py-8 px-6 border-t border-slate-200 dark:border-slate-800 text-center text-slate-600 dark:text-slate-400">
    <p>© 2024 Carol Jardim. All rights reserved.</p>
  </footer>
</Layout>
