---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { DarkModeToggle } from '../components/DarkModeToggle.tsx';
import { ContactForm } from '../components/ContactForm.tsx';
import { projects } from '../data/projects';
---

<Layout title="Carol Jardim - Mobile Developer">
  <!-- Navigation -->
  <nav class="fixed top-0 left-0 right-0 z-50 bg-white dark:bg-slate-900 border-b border-slate-200 dark:border-slate-800 backdrop-blur-sm bg-opacity-95 dark:bg-opacity-95">
    <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-green-400 to-green-600 flex items-center justify-center text-white font-bold text-lg">C</div>
        <span class="font-bold text-xl text-slate-900 dark:text-white">carol</span>
      </div>
      <div class="flex items-center gap-6">
        <a href="#projects" class="text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white transition-colors">Projects</a>
        <a href="#contact" class="text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white transition-colors">Contact</a>
        <DarkModeToggle client:load />
      </div>
    </div>
  </nav>

  <!-- Hero Section -->
  <section class="pt-32 pb-20 px-6">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="text-5xl md:text-6xl font-bold text-slate-900 dark:text-white mb-6 leading-tight">
        Frontend of my brain for projects ✨
      </h1>
      <p class="text-xl text-slate-600 dark:text-slate-400 mb-8 leading-relaxed">
        I'm Carol, a mobile developer specializing in iOS, Android, and React Native. I build beautiful, functional applications that solve real problems.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a 
          href="#projects"
          class="px-8 py-3 bg-green-500 hover:bg-green-600 text-white font-semibold rounded-lg transition-colors"
        >
          See My Work
        </a>
        <a 
          href="#contact"
          class="px-8 py-3 bg-slate-200 dark:bg-slate-800 text-slate-900 dark:text-white hover:bg-slate-300 dark:hover:bg-slate-700 font-semibold rounded-lg transition-colors border border-slate-300 dark:border-slate-700"
        >
          Get in Touch
        </a>
      </div>
    </div>
  </section>

  <!-- Projects Section -->
  <section id="projects" class="py-20 px-6 bg-slate-50 dark:bg-slate-800">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-4xl font-bold text-slate-900 dark:text-white mb-4 text-center">
        Featured Projects
      </h2>
      <p class="text-center text-slate-600 dark:text-slate-400 mb-12">
        A selection of my recent work. More coming soon! 🚀
      </p>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {projects.map((project) => (
          <ProjectCard
            title={project.title}
            description={project.description}
            tags={project.tags}
            link={project.link}
            type={project.type}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section id="contact" class="py-20 px-6">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-4xl font-bold text-slate-900 dark:text-white mb-4 text-center">
        Let's talk!
      </h2>
      <p class="text-center text-slate-600 dark:text-slate-400 mb-12">
        Have a project in mind? I'd love to hear from you. Drop me a message and let's create something amazing together.
      </p>
      
      <div class="bg-slate-50 dark:bg-slate-800 rounded-lg p-8 border border-slate-200 dark:border-slate-700">
        <ContactForm client:load />
      </div>

      <!-- Social Links -->
      <div class="mt-12 text-center">
        <p class="text-slate-600 dark:text-slate-400 mb-4">Or find me on:</p>
        <div class="flex gap-4 justify-center">
          <a href="https://github.com" target="_blank" rel="noopener noreferrer" class="text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white transition-colors">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v 3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          </a>
          <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer" class="text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white transition-colors">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.475-2.236-1.986-2.236-1.081 0-1.722.722-2.004 1.418-.103.25-.129.599-.129.948v5.439h-3.554s.05-8.831 0-9.755h3.554v1.381c.43-.664 1.199-1.61 2.920-1.61 2.134 0 3.734 1.39 3.734 4.382v5.602zM5.337 8.855c-1.144 0-1.915-.759-1.915-1.71 0-.955.77-1.71 1.97-1.71 1.197 0 1.911.754 1.935 1.71 0 .951-.738 1.71-1.990 1.71zm1.581 11.597H3.715V9.697h3.203v10.755zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z"/></svg>
          </a>
          <a href="https://twitter.com" target="_blank" rel="noopener noreferrer" class="text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white transition-colors">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="py-8 px-6 border-t border-slate-200 dark:border-slate-800 text-center text-slate-600 dark:text-slate-400">
    <p>© 2024 Carol Jardim. All rights reserved.</p>
  </footer>
</Layout>
