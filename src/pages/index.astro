---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { DarkModeToggle } from '../components/DarkModeToggle.tsx';
import { BannerSlider } from '../components/BannerSlider.tsx';
import { projects } from '../data/projects';
---

<Layout title="caroljardims">
  <!-- Navigation -->
  <nav class="fixed top-0 left-0 right-0 z-50 bg-white/80 dark:bg-slate-900/80 border-b border-peachy-200 dark:border-slate-800 backdrop-blur-md">
    <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
      <div>
        <h1 class="font-bold text-lg text-slate-900 dark:text-white tracking-tight">caroljardims</h1>
      </div>
      <div class="flex items-center gap-6">
        <a href="#projects" class="text-slate-600 dark:text-slate-400 hover:text-peachy-600 dark:hover:text-peachy-400 transition-colors text-sm font-medium">projetos</a>
        <a href="#support" class="text-slate-600 dark:text-slate-400 hover:text-peachy-600 dark:hover:text-peachy-400 transition-colors text-sm font-medium">apoie</a>
        <a href="#contact" class="text-slate-600 dark:text-slate-400 hover:text-peachy-600 dark:hover:text-peachy-400 transition-colors text-sm font-medium">contato</a>
        <DarkModeToggle client:load />
      </div>
    </div>
  </nav>

  <!-- Hero: Photo Slider -->
  <BannerSlider client:load />

  <!-- Projects Section -->
  <section id="projects" class="py-24 px-6 bg-white dark:bg-slate-900">
    <div class="max-w-5xl mx-auto">
      <div class="mb-14 text-center">
        <h2 class="text-3xl font-bold text-slate-900 dark:text-white mb-3 tracking-tight">projetos</h2>
        <p class="text-slate-500 dark:text-slate-400 text-sm max-w-md mx-auto">
          coisas que criei com carinho e que espero que sejam úteis pra você. em breve muito mais por aqui.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {projects.map((project) => (
          <ProjectCard
            title={project.title}
            description={project.description}
            tags={project.tags}
            link={project.link}
            type={project.type}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section id="contact" class="py-24 px-6 bg-peachy-50 dark:bg-slate-800">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="text-3xl font-bold text-slate-900 dark:text-white mb-4 tracking-tight">me encontre aqui</h2>
      <p class="text-slate-600 dark:text-slate-400 mb-10 leading-relaxed">
        quer bater um papo, propor uma colaboração ou só dizer oi? fico feliz em conversar.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="https://linkedin.com/in/caroljardims"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-3 px-10 py-4 bg-slate-900 dark:bg-white text-white dark:text-slate-900 font-semibold rounded-full transition-all duration-300 shadow-sm hover:shadow-md hover:scale-105 text-sm tracking-wide"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          linkedin
        </a>
        <a
          href="https://github.com/caroljardims"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-3 px-10 py-4 bg-white dark:bg-slate-700 text-slate-900 dark:text-white hover:bg-peachy-100 dark:hover:bg-slate-600 font-semibold rounded-full transition-all duration-300 shadow-sm hover:shadow-md hover:scale-105 text-sm tracking-wide border border-peachy-200 dark:border-slate-600"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
          </svg>
          github
        </a>
      </div>
    </div>
  </section>

  <!-- Buy me a coffee Section -->
  <section id="support" class="py-24 px-6 bg-white dark:bg-slate-900">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="text-3xl font-bold text-slate-900 dark:text-white mb-4 tracking-tight">gostou do que vê?</h2>
      <div class="mb-10 max-w-xs mx-auto text-slate-500 dark:text-slate-400 text-sm leading-loose italic text-left border-l-2 border-peachy-300 dark:border-peachy-600 pl-5">
        <p>a clemência mais intrínseca</p>
        <p>de desfrutar do aroma forte</p>
        <p>do toque quente</p>
        <p>do sabor amargo</p>
        <br />
        <p>e o morno aquece</p>
        <p>e o turvo se esclarece</p>
        <p>e o que é dia</p>
        <p>finalmente</p>
        <p>se reconhece</p>
      </div>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/pix"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-3 px-10 py-4 bg-peachy-600 hover:bg-peachy-500 text-slate-800 font-semibold rounded-full transition-all duration-300 shadow-sm hover:shadow-md text-sm tracking-wide"
        >
          me pague um cafezinho via pix ☕️
        </a>
        ou
        <a
          href="https://buymeacoffee.com/caroljardims"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-3 px-10 py-4 bg-peachy-600 hover:bg-peachy-500 text-slate-800 font-semibold rounded-full transition-all duration-300 shadow-sm hover:shadow-md text-sm tracking-wide"
        >
          buy me a coffee (no cartão!)
        </a>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="py-8 px-6 border-t border-slate-100 dark:border-slate-800 text-center text-slate-400 dark:text-slate-600 text-sm">
    <p>© 2026 Carol Jardim · feito com carinho</p>
  </footer>
</Layout>
