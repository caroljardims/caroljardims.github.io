---
const jogo = "https://decifragem.web.app";
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Decifragem</title>
    <script is:inline define:vars={{ jogo }}>
      window.open(jogo, "_blank");
      history.back();
    </script>
  </head>
  <body style="font-family: system-ui; padding: 2rem; background: #0a0b12; color: #e8e9f2">
    <p><a href={jogo} target="_blank" rel="noopener noreferrer" style="color: #c4b5fd">Abrir Decifragem</a></p>
  </body>
</html>
