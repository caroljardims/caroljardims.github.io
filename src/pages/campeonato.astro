---
// src/pages/campeonato.astro
import Layout from '../layouts/Layout.astro';
---

<Layout title="Campeonato · caroljardims">
  <div class="min-h-screen bg-white dark:bg-slate-900 flex flex-col">
    <!-- Header -->
    <header class="border-b border-peachy-200 dark:border-slate-800 px-6 py-4 flex items-center gap-4">
      <a
        href="/"
        class="text-slate-500 dark:text-slate-400 hover:text-peachy-600 dark:hover:text-peachy-400 transition-colors text-sm font-medium"
      >
        ← voltar
      </a>
      <h1 class="text-lg font-bold text-slate-900 dark:text-white tracking-tight">campeonato</h1>
    </header>

    <!-- Main content -->
    <main class="flex-1 flex flex-col items-center justify-center px-6 py-24 text-center">
      <div class="max-w-md">
        <div class="text-6xl mb-8">🏆</div>
        <h2 class="text-3xl font-bold text-slate-900 dark:text-white mb-4 tracking-tight">
          em breve
        </h2>
        <p class="text-slate-500 dark:text-slate-400 text-sm leading-relaxed">
          aqui você vai montar campeonatos do zero — cadastrar os times, definir as regras e acompanhar cada disputa. ainda estamos construindo isso com carinho.
        </p>
      </div>
    </main>

    <!-- Footer -->
    <footer class="py-6 px-6 border-t border-slate-100 dark:border-slate-800 text-center text-slate-400 dark:text-slate-600 text-sm">
      <p>© 2026 Carol Jardim · feito com carinho</p>
    </footer>
  </div>
</Layout>
