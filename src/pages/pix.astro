---
import '../styles/global.css';
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Pix para Carol Jardim" />
    <title>pix 💸</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;900&display=swap" rel="stylesheet" />
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        min-height: 100vh;
        font-family: 'Inter', system-ui, sans-serif;
        background: linear-gradient(160deg, #4c1d95 0%, #7c3aed 30%, #db2777 70%, #f97316 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 32px 24px;
        color: #fff;
      }
      .card {
        background: rgba(255,255,255,0.1);
        backdrop-filter: blur(12px);
        border-radius: 24px;
        padding: 40px 32px;
        max-width: 400px;
        width: 100%;
        text-align: center;
      }
      .icon { font-size: 56px; margin-bottom: 16px; }
      h1 { font-size: 32px; font-weight: 900; margin-bottom: 8px; }
      .subtitle { color: rgba(255,255,255,0.6); font-size: 14px; margin-bottom: 32px; }
      .label {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: rgba(255,255,255,0.5);
        margin-bottom: 10px;
        text-align: left;
      }
      .pix-box {
        background: rgba(0,0,0,0.2);
        border-radius: 14px;
        padding: 16px;
        font-size: 11px;
        color: rgba(255,255,255,0.8);
        text-align: left;
        line-height: 1.6;
        margin-bottom: 12px;
        font-family: monospace;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      .copy-btn {
        width: 100%;
        padding: 16px;
        border-radius: 14px;
        border: none;
        background: linear-gradient(90deg, #f97316, #db2777);
        color: #fff;
        font-weight: 700;
        font-size: 16px;
        cursor: pointer;
        font-family: inherit;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        transition: opacity 0.2s;
      }
      .copy-btn:active { opacity: 0.8; }
      .success {
        margin-top: 12px;
        font-size: 13px;
        color: rgba(255,255,255,0.6);
        min-height: 20px;
      }
      .name {
        margin-top: 24px;
        font-size: 13px;
        color: rgba(255,255,255,0.4);
      }
    </style>
  </head>
  <body>
    <div class="card">
      <div class="icon">💸</div>
      <h1>me pague um drink</h1>
      <p class="subtitle">copie a chave pix abaixo</p>

      <div style="margin-bottom: 24px; display: flex; flex-direction: column; align-items: center;">
        <p class="label" style="text-align:center; margin-bottom: 12px;">escaneie o qr code</p>
        <img src="/pix-qr.png" alt="QR Code Pix" style="width: 180px; height: 180px; border-radius: 16px; object-fit: contain; background: #fff; padding: 8px;" />
      </div>

      <p class="label">ou copie a chave pix</p>
      <div class="pix-box" id="pix-key">
        00020101021126580014br.gov.bcb.pix013690ec09c7-ce7a-48e7-a5eb-919d4716bde45204000053039865802BR5924CAROLINE JARDIM SIQUEIRA6009SAO PAULO622905251KNWBTFDP14K4X3DAFDH9Z1S06304209F
      </div>

      <button class="copy-btn" id="copy-btn">
        <span id="btn-icon">📋</span>
        <span id="btn-text">copiar chave</span>
      </button>
      <p class="success" id="success-msg"></p>

      <p class="name">Caroline Jardim Siqueira</p>
    </div>

    <script>
      const btn = document.getElementById('copy-btn');
      const key = document.getElementById('pix-key').innerText.trim();
      const icon = document.getElementById('btn-icon');
      const text = document.getElementById('btn-text');
      const msg = document.getElementById('success-msg');

      btn.addEventListener('click', async () => {
        await navigator.clipboard.writeText(key);
        icon.textContent = '✅';
        text.textContent = 'copiado!';
        msg.textContent = 'chave copiada — agora é só colar no seu banco 🥂';
        setTimeout(() => {
          icon.textContent = '📋';
          text.textContent = 'copiar chave';
          msg.textContent = '';
        }, 3000);
      });
    </script>
  </body>
</html>
