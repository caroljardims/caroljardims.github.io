---
import '../styles/global.css';
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Pix para Carol Jardim" />
    <title>pix · caroljardims</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-peachy-50 dark:bg-slate-900 min-h-screen flex flex-col items-center justify-center px-6 py-12" style="font-family:'Inter',system-ui,sans-serif;">

    <div class="w-full max-w-sm flex flex-col gap-6">

      <!-- Back -->
      <a href="javascript:history.back()" class="text-slate-500 dark:text-slate-400 hover:text-peachy-600 dark:hover:text-peachy-400 transition-colors text-sm font-medium self-start">
        ← voltar
      </a>

      <!-- Card -->
      <div class="bg-white dark:bg-slate-800 border border-peachy-200 dark:border-slate-700 rounded-2xl p-8 flex flex-col items-center gap-6 shadow-sm">

        <div class="text-5xl">💸</div>

        <div class="text-center">
          <h1 class="text-2xl font-bold text-slate-900 dark:text-white tracking-tight mb-1">obrigada pelo carinho</h1>
          <p class="text-slate-500 dark:text-slate-400 text-sm">copie a chave pix ou escaneie o qr code</p>
        </div>

        <!-- QR Code -->
        <img
          src="/pix-qr.png"
          alt="QR Code Pix"
          class="w-44 h-44 rounded-xl border border-peachy-200 dark:border-slate-600 object-contain bg-white p-2"
        />

        <!-- Pix key -->
        <div class="w-full flex flex-col gap-2">
          <p class="text-xs font-bold uppercase tracking-widest text-peachy-600 dark:text-peachy-400">chave pix</p>
          <div
            id="pix-key"
            class="w-full px-4 py-3 rounded-xl bg-peachy-50 dark:bg-slate-700 border border-peachy-200 dark:border-slate-600 text-slate-600 dark:text-slate-300 text-xs font-mono truncate"
          >
            00020101021126580014br.gov.bcb.pix013690ec09c7-ce7a-48e7-a5eb-919d4716bde45204000053039865802BR5924CAROLINE JARDIM SIQUEIRA6009SAO PAULO622905251KNWBTFDP14K4X3DAFDH9Z1S06304209F
          </div>
        </div>

        <!-- Copy button -->
        <button
          id="copy-btn"
          class="w-full py-3 px-6 bg-slate-900 dark:bg-white text-white dark:text-slate-900 font-semibold rounded-full text-sm tracking-wide hover:scale-105 transition-transform shadow-sm flex items-center justify-center gap-2"
        >
          <span id="btn-icon">📋</span>
          <span id="btn-text">copiar chave</span>
        </button>

        <p id="success-msg" class="text-sm text-peachy-600 dark:text-peachy-400 min-h-[20px] text-center"></p>

        <p class="text-slate-400 dark:text-slate-600 text-xs">@caroljardims</p>
      </div>

    </div>

    <script>
      const btn = document.getElementById('copy-btn');
      const key = document.getElementById('pix-key').innerText.trim();
      const icon = document.getElementById('btn-icon');
      const text = document.getElementById('btn-text');
      const msg = document.getElementById('success-msg');

      btn.addEventListener('click', async () => {
        await navigator.clipboard.writeText(key);
        icon.textContent = '✅';
        text.textContent = 'copiado!';
        msg.textContent = 'chave copiada — agora é só colar no seu banco';
        setTimeout(() => {
          icon.textContent = '📋';
          text.textContent = 'copiar chave';
          msg.textContent = '';
        }, 3000);
      });
    </script>
  </body>
</html>
