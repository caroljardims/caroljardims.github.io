---
import '../styles/global.css';
import TextosSection from '../components/TextosSection.tsx';
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Textos de Carol Jardim" />
    <title>escritas · caroljardims</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-peachy-50 dark:bg-slate-900 min-h-screen px-6 py-12" style="font-family:'Inter',system-ui,sans-serif;">
    <div class="w-full max-w-2xl mx-auto flex flex-col gap-8">

      <a href="/" class="text-slate-500 dark:text-slate-400 hover:text-peachy-600 dark:hover:text-peachy-400 transition-colors text-sm font-medium self-start">
        ← voltar
      </a>

      <div>
        <h1 class="text-3xl font-bold text-slate-900 dark:text-white tracking-tight">escritas</h1>
        <p class="text-slate-500 dark:text-slate-400 mt-2 text-sm">coisas que escrevi e quis guardar em algum lugar</p>
      </div>

      <TextosSection client:load />

      <footer class="text-center py-6 text-sm text-slate-500 dark:text-slate-400">
        Gostou?{" "}
        <a href="/pix" class="underline">Me pague um café via Pix</a>
        {" "}ou{" "}
        <a href="https://buymeacoffee.com/caroljardims" target="_blank" rel="noopener noreferrer" class="underline">
          Buy Me a Coffee
        </a> ☕
      </footer>

    </div>
  </body>
</html>
